<script src="./views/sorttable.js"></script>
<style>
  .data-table { font-family: Arial; border-collapse: collapse; font-size: 8pt; margin-top: 20px; }
  .data-table td, .data-table th { border: 1px solid #ddd; padding: 8px; }
  .data-table tr:nth-child(even) { background-color: #f2f2f2; }
  .data-table tr:hover * { background-color: rgb(194, 149, 141) !important; }
  .data-table th { background-color: #4CAF50; color: white; }
  .data-table td { white-space: nowrap; }
  .number { text-align: right; }
  .cover { position: relative; }
  .cover-lg { display: none; position: absolute; left: 50px; top: -20px; z-index: 10; }
  .cover:hover .cover-lg { display: block; }
  .cover:hover > img:first-child { opacity: 0; }
  .genre-pill, .score-pill { display: inline-block; padding: 2px 8px; border-radius: 10px; color: white; font-size: 7pt; }
  .score-pill { margin-left: 4px; }
  .not-must-see a { color: #aaa; }
  .rating-pill { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 7pt; font-weight: bold; }
  .rating-g { background-color: #dcfce7; color: #166534; }
  .rating-pg { background-color: #dcfce7; color: #166534; }
  .rating-pg13 { background-color: #fff7ed; color: #9a3412; }
  .rating-r { background-color: #fee2e2; color: #991b1b; }
  th { position: sticky; top: 20px; }
  h2 { font-family: Arial; margin-top: 30px; }
</style>

<h2>Books (<%= @books.count %>)</h2>
<table class="data-table sortable">
  <tr>
    <th>Book Type</th>
    <th>Holds</th>
    <th>Copies</th>
    <th>Available</th>
    <th>On Order</th>
    <th>Rating</th>
    <th>Book</th>
    <th>Author</th>
    <th>Year</th>
    <th>Genre</th>
    <th>Audiences</th>
    <th>Content Type</th>
  </tr>
  <% @books.each do |book| %>
    <tr>
      <td><%= book.book_type %></td>
      <td class="number"><%= book.holds %></td>
      <td class="number"><%= book.copies %></td>
      <td class="number"><%= book.available %></td>
      <td class="number"><%= book.on_order %></td>
      <td class="number"><%= book.rating %></td>
      <td><a href="https://tpl.bibliocommons.com<%= book.href %>"><%= book.title %></a></td>
      <td><%= book.author %></td>
      <td class="number"><%= book.year %></td>
      <td><% unless book.genre.empty? %><span class="genre-pill" style="background-color: <%= genre_color(book.genre) %>"><%= book.genre %></span><% end %></td>
      <td><%= book.audiences %></td>
      <td><%= book.content_type %></td>
    </tr>
  <% end %>
</table>

<h2>Movies (<%= @movies.count %>)</h2>
<table class="data-table sortable">
  <tr>
    <th>Holds</th>
    <th>Copies</th>
    <th>Available</th>
    <th>On Order</th>
    <th>Rating</th>
    <th>Title</th>
    <th>Year</th>
    <th>Rated</th>
    <th>Runtime (min)</th>
    <th>Genre</th>
    <th>Box Office ($M)</th>
    <th>RT (%)</th>
    <th>MC (/100)</th>
    <th>Audiences</th>
  </tr>
  <% @movies.each do |movie| %>
    <tr>
      <td class="number"><%= movie.holds %></td>
      <td class="number"><%= movie.copies %></td>
      <td class="number"><%= movie.available %></td>
      <td class="number"><%= movie.on_order %></td>
      <td class="number"><%= movie.rating %></td>
      <td<%= ' class="not-must-see"' unless movie.must_see? %>><a href="https://tpl.bibliocommons.com<%= movie.href %>"><%= movie.display_title %></a></td>
      <td class="number"><%= movie.display_year %></td>
      <td><%= rated_pill(movie.rated) %></td>
      <td class="number"><%= movie.runtime %></td>
      <td><%= movie.genre %></td>
      <td class="number"><%= movie.box_office %></td>
      <td class="number"><a href="<%= movie.rotten_tomatoes_url %>"><%= movie.rotten_tomatoes %></a></td>
      <td class="number"><% unless movie.metacritic.empty? %><a href="<%= movie.metacritic_url %>"><%= movie.metacritic %></a><% end %></td>
      <td><%= movie.audiences %></td>
    </tr>
  <% end %>
</table>
