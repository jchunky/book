<script src="./views/sorttable.js"></script>
<style>
  #books { font-family: Arial; border-collapse: collapse; font-size: 8pt; margin-top: 20px; }
  #books td, #books th { border: 1px solid #ddd; padding: 8px; }
  #books tr:nth-child(even) { background-color: #f2f2f2; }
  #books tr:hover * { background-color: rgb(194, 149, 141) !important; }
  #books th { background-color: #4CAF50; color: white; }
  #books td { white-space: nowrap; }
  .number { text-align: right; }
  th { position: sticky; top: 20; }
</style>

<table id="books" class="sortable">
  <tr>
    <th>Book Type</th>
    <th>Holds</th>
    <th>Copies</th>
    <th>Available</th>
    <th>Rating</th>
    <th>Book</th>
    <th>Author</th>
    <th>Year</th>
    <th>Availability Status</th>
    <th>Audiences</th>
    <th>Content Type</th>
    <th>Genre</th>
    <th>Subject</th>
  </tr>
  <% @books.each do |book| %>
    <tr>
      <td><%= book.book_type %></td>
      <td class="number"><%= book.holds %></td>
      <td class="number"><%= book.copies %></td>
      <td class="number"><%= book.available %></td>
      <td class="number"><%= book.rating %></td>
      <td><a href="https://tpl.bibliocommons.com<%= book.href %>"><%= book.title %></a></td>
      <td><%= book.author %></td>
      <td><%= book.year %></td>
      <td><%= book.availability_status %></td>
      <td><%= book.audiences %></td>
      <td><%= book.content_type %></td>
      <td><%= book.genre %></td>
      <td><%= book.subject %></td>
    </tr>
  <% end %>
</table>
