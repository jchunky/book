<head>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <link href="https://cdn.datatables.net/2.3.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.3.2/js/dataTables.min.js"></script>
  <style>
    body { max-width: 95%; margin: 0; padding-left: 20px; }
    .dt-container { width: fit-content; }
    .dataTable { font-family: Arial; border-collapse: collapse; font-size: 8pt; margin-top: 20px; width: auto !important; }
    .dataTable tr:nth-child(even) { background-color: #f2f2f2; }
    .dataTable tbody tr:hover * { background-color: rgb(194, 149, 141) !important; }
    .dataTable th { background-color: #4CAF50; color: white; }
    .dataTable td { white-space: nowrap; }
    .number { text-align: right; }
    .cover { position: relative; }
    .cover-lg { display: none; position: absolute; left: 50px; top: -20px; z-index: 10; }
    .cover:hover .cover-lg { display: block; }
    .cover:hover > img:first-child { opacity: 0; }
    .genre-pill, .score-pill { display: inline-block; padding: 2px 8px; border-radius: 10px; color: white; font-size: 7pt; }
    .score-pill { margin-left: 4px; }
    .not-must-see a { color: #aaa; }
    .rating-pill { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 7pt; font-weight: bold; }
    .rating-g { background-color: #dcfce7; color: #166534; }
    .rating-pg { background-color: #dcfce7; color: #166534; }
    .rating-pg13 { background-color: #fff7ed; color: #9a3412; }
    .rating-r { background-color: #fee2e2; color: #991b1b; }
    .avail-none { color: #991b1b; background-color: #fee2e2; }
    .avail-low { color: #9a3412; background-color: #fff7ed; }
    .avail-ok { color: #166534; background-color: #dcfce7; }
    .audience-pill { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 7pt; font-weight: bold; }
    .audience-juvenile { background-color: #dcfce7; color: #166534; }
    .audience-teen { background-color: #fee2e2; color: #991b1b; }
    .audience-adult { background-color: #e2e8f0; color: #334155; }
    h2 { font-family: Arial; margin: 0; }
    #books thead th, #movies thead th {
      position: sticky;
      top: 0;
      z-index: 2;
    }
  </style>
  <script>
    $(function() {
      $('#books').DataTable({
        order: [[4, 'desc']],
        paging: false,
        layout: {
          topStart: function() {
            var h2 = document.createElement('h2');
            h2.textContent = 'Books (<%= @books.count %>)';
            return h2;
          }
        }
      });
      $('#movies').DataTable({
        order: [[4, 'desc']],
        paging: false,
        layout: {
          topStart: function() {
            var h2 = document.createElement('h2');
            h2.textContent = 'Movies (<%= @movies.count %>)';
            return h2;
          }
        }
      });
    });
  </script>
</head>
<body>
  <table id="books">
    <thead>
      <tr>
        <th>Holds</th>
        <th>Copies</th>
        <th>Available</th>
        <th>On Order</th>
        <th>Rating</th>
        <th>Book</th>
        <th>Author</th>
        <th>Year</th>
        <th>Genre</th>
        <th>Audiences</th>
        <th>Content Type</th>
      </tr>
    </thead>
    <tbody>
      <% @books.each do |book| %>
        <tr>
          <td class="number"><%= book.holds %></td>
          <td class="number"><%= book.copies %></td>
          <td class="number <%= availability_class(book.available, book.copies) %>"><%= book.available %></td>
          <td class="number"><%= book.on_order %></td>
          <td class="number"><%= book.rating %></td>
          <td><a href="https://tpl.bibliocommons.com<%= book.href %>"><%= book.title %></a></td>
          <td><%= book.author %></td>
          <td class="number"><%= book.year %></td>
          <td><% unless book.genre.empty? %><span class="genre-pill" style="background-color: <%= genre_color(book.genre) %>"><%= book.genre %></span><% end %></td>
          <td><%= audience_pill(book) %></td>
          <td><%= book.content_type %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <table id="movies">
    <thead>
      <tr>
        <th>Holds</th>
        <th>Copies</th>
        <th>Available</th>
        <th>On Order</th>
        <th>Rating</th>
        <th>Title</th>
        <th>Year</th>
        <th>Rated</th>
        <th>Runtime (min)</th>
        <th>Genre</th>
        <th>Box Office ($M)</th>
        <th>RT (%)</th>
        <th>MC (/100)</th>
        <th>Audiences</th>
      </tr>
    </thead>
    <tbody>
      <% @movies.each do |movie| %>
        <tr>
          <td class="number"><%= movie.holds %></td>
          <td class="number"><%= movie.copies %></td>
          <td class="number <%= availability_class(movie.available, movie.copies) %>"><%= movie.available %></td>
          <td class="number"><%= movie.on_order %></td>
          <td class="number"><%= movie.rating %></td>
          <td<%= ' class="not-must-see"' unless movie.must_see? %>><a href="https://tpl.bibliocommons.com<%= movie.href %>"><%= movie.display_title %></a></td>
          <td class="number"><%= movie.display_year %></td>
          <td><%= rated_pill(movie.rated) %></td>
          <td class="number"><%= movie.runtime %></td>
          <td><%= movie.genre %></td>
          <td class="number"><%= movie.box_office %></td>
          <td class="number"><a href="<%= movie.rotten_tomatoes_url %>"><%= movie.rotten_tomatoes %></a></td>
          <td class="number"><% unless movie.metacritic.empty? %><a href="<%= movie.metacritic_url %>"><%= movie.metacritic %></a><% end %></td>
          <td><%= audience_pill(movie) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</body>
