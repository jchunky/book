<head>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/list.js/2.3.1/list.min.js"></script>
  <style>
    body { max-width: 95%; margin: 0; padding-left: 20px; }
    table { font-family: Arial; border-collapse: collapse; font-size: 8pt; margin-top: 10px; width: auto; }
    table tr:nth-child(even) { background-color: #f2f2f2; }
    table tbody tr:hover * { background-color: rgb(194, 149, 141) !important; }
    table th { background-color: #4CAF50; color: white; text-align: left; padding: 4px 8px; }
    table td { white-space: nowrap; padding: 2px 8px; }
    th.sort { cursor: pointer; user-select: none; }
    th.sort::after { content: ' ⇕'; font-size: 7pt; opacity: 0.5; }
    th.sort.asc::after { content: ' ↑'; opacity: 1; }
    th.sort.desc::after { content: ' ↓'; opacity: 1; }
    .number { text-align: right; }
    .cover { position: relative; }
    .cover-lg { display: none; position: absolute; left: 50px; top: -20px; z-index: 10; }
    .cover:hover .cover-lg { display: block; }
    .cover:hover > img:first-child { opacity: 0; }
    .score-pill { display: inline-block; padding: 2px 8px; border-radius: 10px; color: white; font-size: 7pt; }
    .score-pill { margin-left: 4px; }
    a:visited { color: #b45309; }
    .not-must-see a { color: #aaa; }
    .low-popularity { color: #aaa; }
    h2 { font-family: Arial; margin: 0; display: inline; }
    .table-header { margin-top: 16px; display: flex; align-items: baseline; gap: 12px; }
    input.search { font-size: 9pt; padding: 4px 8px; border: 1px solid #ccc; border-radius: 4px; width: 200px; }
    #books thead th, #movies thead th {
      position: sticky;
      top: 0;
      z-index: 2;
    }
  </style>
</head>
<body>
  <div id="books-list">
    <div class="table-header">
      <h2>Books (<%= book_count %>)</h2>
      <input class="search" placeholder="Search...">
    </div>
    <table id="books">
      <thead>
        <tr>
          <th class="sort" data-sort="holds">Holds</th>
          <th class="sort" data-sort="copies">Copies</th>
          <th class="sort" data-sort="available">Available</th>
          <th class="sort" data-sort="on-order">On Order</th>
          <th class="sort" data-sort="popularity">Popularity</th>
          <th class="sort" data-sort="book-title">Book</th>
          <th class="sort" data-sort="author">Author</th>
          <th class="sort" data-sort="year">Year</th>
          <th class="sort" data-sort="genre">Genre</th>
          <th class="sort" data-sort="audiences">Audience</th>
          <th class="sort" data-sort="content-type">Content Type</th>
        </tr>
      </thead>
      <tbody class="list">
        <% @books.each do |row| %>
          <tr>
            <td class="number holds"><%= row.holds %></td>
            <td class="number copies"><%= row.copies %></td>
            <td class="number available" style="<%= row.availability_style %>"><%= row.available %></td>
            <td class="number on-order"><%= row.on_order %></td>
            <td class="<%= row.popularity_class %>"><%= row.popularity %></td>
            <td><a href="https://tpl.bibliocommons.com<%= row.href %>"><span class="book-title"><%= row.title %></span></a></td>
            <td class="author"><%= row.author %></td>
            <td class="number year"><%= row.year %></td>
            <td class="genre"><%= row.genre_html %></td>
            <td class="audiences"><%= row.audience_pill %></td>
            <td class="content-type"><%= row.fiction_flag %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div id="movies-list">
    <div class="table-header">
      <h2>Movies (<%= movie_count %>)</h2>
      <input class="search" placeholder="Search...">
    </div>
    <table id="movies">
      <thead>
        <tr>
          <th class="sort" data-sort="holds">Holds</th>
          <th class="sort" data-sort="copies">Copies</th>
          <th class="sort" data-sort="available">Available</th>
          <th class="sort" data-sort="on-order">On Order</th>
          <th class="sort" data-sort="popularity">Popularity</th>
          <th class="sort" data-sort="title">Title</th>
          <th class="sort" data-sort="year">Year</th>
          <th class="sort" data-sort="rated">Rated</th>
          <th class="sort" data-sort="runtime">Runtime (min)</th>
          <th class="sort" data-sort="genre">Genre</th>
          <th class="sort" data-sort="box-office">Box Office ($M)</th>
          <th class="sort" data-sort="rt">RT (%)</th>
          <th class="sort" data-sort="mc">MC (/100)</th>
          <th class="sort" data-sort="audiences">Audience</th>
        </tr>
      </thead>
      <tbody class="list">
        <% @movies.each do |row| %>
          <tr>
            <td class="number holds"><%= row.holds %></td>
            <td class="number copies"><%= row.copies %></td>
            <td class="number available" style="<%= row.availability_style %>"><%= row.available %></td>
            <td class="number on-order"><%= row.on_order %></td>
            <td class="<%= row.popularity_class %>"><%= row.popularity %></td>
            <td<%= " class=\"#{row.title_class}\"" if row.title_class %>><a href="https://tpl.bibliocommons.com<%= row.href %>"><span class="title"><%= row.display_title %></span></a></td>
            <td class="number year"><%= row.display_year %></td>
            <td class="rated"><%= row.rated_pill %></td>
            <td class="number runtime"><%= row.runtime %></td>
            <td class="genre"><%= row.genre %></td>
            <td class="number box-office"><%= row.box_office %></td>
            <td class="number"><a href="<%= row.rotten_tomatoes_url %>"><span class="rt"><%= row.rotten_tomatoes %></span></a></td>
            <td class="number"><%= row.metacritic_html %></td>
            <td class="audiences"><%= row.audience_pill %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <script>
    var booksList = new List('books-list', {
      valueNames: ['holds', 'copies', 'available', 'on-order', 'popularity', 'book-title', 'author', 'year', 'genre', 'audiences', 'content-type']
    });
    booksList.sort('popularity', { order: 'desc' });

    var moviesList = new List('movies-list', {
      valueNames: ['holds', 'copies', 'available', 'on-order', 'popularity', 'title', 'year', 'rated', 'runtime', 'genre', 'box-office', 'rt', 'mc', 'audiences']
    });
    moviesList.sort('popularity', { order: 'desc' });
  </script>
</body>
