<head>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/list.js/2.3.1/list.min.js"></script>
  <style>
    body { max-width: 95%; margin: 0; padding-left: 20px; }
    table { font-family: Arial; border-collapse: collapse; font-size: 8pt; margin-top: 10px; width: auto; }
    table tr:nth-child(even) { background-color: #f2f2f2; }
    table tbody tr:hover * { background-color: rgb(194, 149, 141) !important; }
    table th { background-color: #4CAF50; color: white; text-align: left; }
    table td { white-space: nowrap; padding-left: 8px; padding-right: 8px; }
    th.sort { cursor: pointer; user-select: none; }
    th.sort::after { content: ' ⇕'; font-size: 7pt; opacity: 0.5; }
    th.sort.asc::after { content: ' ↑'; opacity: 1; }
    th.sort.desc::after { content: ' ↓'; opacity: 1; }
    .number { text-align: right; }
    .cover { position: relative; }
    .cover-lg { display: none; position: absolute; left: 50px; top: -20px; z-index: 10; }
    .cover:hover .cover-lg { display: block; }
    .cover:hover > img:first-child { opacity: 0; }
    .score-pill { display: inline-block; padding: 2px 8px; border-radius: 10px; color: white; font-size: 7pt; }
    .score-pill { margin-left: 4px; }
    .not-must-see a { color: #aaa; }
    .low-rating { color: #aaa; }
    .rating-g { color: #16a34a; font-weight: bold; }
    .rating-pg { color: #16a34a; font-weight: bold; }
    .rating-pg13 { color: #ca8a04; font-weight: bold; }
    .rating-r { color: #dc2626; font-weight: bold; }
    .avail-none { color: #991b1b; background-color: #fee2e2; }
    .avail-low { color: #9a3412; background-color: #fff7ed; }
    .avail-ok { color: #166534; background-color: #dcfce7; }
    .audience-juvenile { color: #16a34a; font-weight: bold; }
    .audience-teen { color: #dc2626; font-weight: bold; }
    .audience-adult { color: #64748b; font-weight: bold; }
    h2 { font-family: Arial; margin: 0; }
    input.search { font-size: 9pt; padding: 4px 8px; margin-top: 16px; border: 1px solid #ccc; border-radius: 4px; width: 200px; }
    #books thead th, #movies thead th {
      position: sticky;
      top: 0;
      z-index: 2;
    }
  </style>
</head>
<body>
  <div id="books-list">
    <input class="search" placeholder="Search books...">
    <h2>Books (<%= @books.count %>)</h2>
    <table id="books">
      <thead>
        <tr>
          <th class="sort" data-sort="holds">Holds</th>
          <th class="sort" data-sort="copies">Copies</th>
          <th class="sort" data-sort="available">Available</th>
          <th class="sort" data-sort="on-order">On Order</th>
          <th class="sort" data-sort="rating">Rating</th>
          <th class="sort" data-sort="book-title">Book</th>
          <th class="sort" data-sort="author">Author</th>
          <th class="sort" data-sort="year">Year</th>
          <th class="sort" data-sort="genre">Genre</th>
          <th class="sort" data-sort="audiences">Audiences</th>
          <th class="sort" data-sort="content-type">Content Type</th>
        </tr>
      </thead>
      <tbody class="list">
        <% @books.each do |book| %>
          <tr>
            <td class="number holds"><%= book.holds %></td>
            <td class="number copies"><%= book.copies %></td>
            <td class="number <%= availability_class(book.available, book.copies) %> available"><%= book.available %></td>
            <td class="number on-order"><%= book.on_order unless book.on_order.zero? %></td>
            <td class="number<%= ' low-rating' if book.rating < 100 %> rating"><%= book.rating %></td>
            <td><a href="https://tpl.bibliocommons.com<%= book.href %>"><span class="book-title"><%= book.title %></span></a></td>
            <td class="author"><%= book.author %></td>
            <td class="number year"><%= book.year %></td>
            <td class="genre"><% unless book.genre.empty? %><span style="color: <%= genre_color(book.genre) %>; font-weight: bold;"><%= book.genre %></span><% end %></td>
            <td class="audiences"><%= audience_pill(book) %></td>
            <td class="content-type"><%= "F" unless book.content_type == "NONFICTION" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div id="movies-list">
    <input class="search" placeholder="Search movies...">
    <h2>Movies (<%= @movies.count %>)</h2>
    <table id="movies">
      <thead>
        <tr>
          <th class="sort" data-sort="holds">Holds</th>
          <th class="sort" data-sort="copies">Copies</th>
          <th class="sort" data-sort="available">Available</th>
          <th class="sort" data-sort="on-order">On Order</th>
          <th class="sort" data-sort="rating">Rating</th>
          <th class="sort" data-sort="title">Title</th>
          <th class="sort" data-sort="year">Year</th>
          <th class="sort" data-sort="rated">Rated</th>
          <th class="sort" data-sort="runtime">Runtime (min)</th>
          <th class="sort" data-sort="genre">Genre</th>
          <th class="sort" data-sort="box-office">Box Office ($M)</th>
          <th class="sort" data-sort="rt">RT (%)</th>
          <th class="sort" data-sort="mc">MC (/100)</th>
          <th class="sort" data-sort="audiences">Audiences</th>
        </tr>
      </thead>
      <tbody class="list">
        <% @movies.each do |movie| %>
          <tr>
            <td class="number holds"><%= movie.holds %></td>
            <td class="number copies"><%= movie.copies %></td>
            <td class="number <%= availability_class(movie.available, movie.copies) %> available"><%= movie.available %></td>
            <td class="number on-order"><%= movie.on_order unless movie.on_order.zero? %></td>
            <td class="number<%= ' low-rating' if movie.rating < 100 %> rating"><%= movie.rating %></td>
            <td<%= ' class="not-must-see"' unless movie.must_see? %>><a href="https://tpl.bibliocommons.com<%= movie.href %>"><span class="title"><%= movie.display_title %></span></a></td>
            <td class="number year"><%= movie.display_year %></td>
            <td class="rated"><%= rated_pill(movie.rated) %></td>
            <td class="number runtime"><%= movie.runtime %></td>
            <td class="genre"><%= movie.genre %></td>
            <td class="number box-office"><%= movie.box_office if movie.box_office.to_i > 0 %></td>
            <td class="number"><a href="<%= movie.rotten_tomatoes_url %>"><span class="rt"><%= movie.rotten_tomatoes %></span></a></td>
            <td class="number"><% unless movie.metacritic.empty? %><a href="<%= movie.metacritic_url %>"><span class="mc"><%= movie.metacritic %></span></a><% end %></td>
            <td class="audiences"><%= audience_pill(movie) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <script>
    var booksList = new List('books-list', {
      valueNames: ['holds', 'copies', 'available', 'on-order', 'rating', 'book-title', 'author', 'year', 'genre', 'audiences', 'content-type']
    });
    booksList.sort('rating', { order: 'desc' });

    var moviesList = new List('movies-list', {
      valueNames: ['holds', 'copies', 'available', 'on-order', 'rating', 'title', 'year', 'rated', 'runtime', 'genre', 'box-office', 'rt', 'mc', 'audiences']
    });
    moviesList.sort('rating', { order: 'desc' });
  </script>
</body>
